// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Audio {
  id           String   @id @default(cuid())
  filename     String   @unique
  filepath     String
  date         String
  startTime    String
  endTime      String
  personTag    String
  lastPosition Float    @default(0)
  createdAt    DateTime @default(now())
}

model Feedback {
  id                  String   @id @default(cuid())
  audioId             String?
  audioFilename       String?
  audioDate           String?
  audioPersonTag      String?
  audioStartTime      String?
  audioEndTime        String?
  subtitleFile        String
  subtitleIndex       Int?
  subtitleStart       Float?
  subtitleEnd         Float?
  subtitleText        String?
  subtitleSourceKind  String?
  subtitleSourcePath  String?
  subtitleSourceIndex Int?
  subtitleAbsStart    Float?
  subtitleAbsEnd      Float?
  message             String
  processingStatus    String   @default("待处理")
  processedAt         DateTime?
  repairStatus        String   @default("pending")
  repairSummary       String?
  repairConfidence    Float?
  repairedText        String?
  repairPatchJson     String?
  repairError         String?
  repairedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt

  repairJobs FeedbackRepairJob[]
}

model FeedbackRepairJob {
  id            String   @id @default(cuid())
  feedbackId    String
  status        String   @default("pending")
  attempt       Int      @default(0)
  model         String?
  promptVersion String?
  inputJson     String?
  outputJson    String?
  patchJson     String?
  error         String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([feedbackId, createdAt])
}

model InferHost {
  id            String            @id @default(cuid())
  name          String            @unique
  sshHost       String
  sshPort       Int               @default(22)
  sshUser       String
  workspacePath String
  status        String            @default("active")
  gpuPolicy     String            @default("shared_service")
  notes         String?
  deployments   ModelDeployment[]
  evalRuns      EvalRun[]
  liveSessions  LiveSession[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ModelDeployment {
  id                    String        @id @default(cuid())
  inferHostId           String
  name                  String
  slug                  String        @unique
  baseModelPath         String
  adapterPath           String?
  systemPromptFile      String?
  runnerKind            String        @default("batch_chat_eval")
  runnerScriptPath      String?
  serviceMode           String        @default("offline_only")
  serviceStatus         String        @default("stopped")
  serviceBaseUrl        String?
  serviceChatPath       String?
  serviceStreamPath     String?
  serviceSessionName    String?
  serviceLogPath        String?
  serviceStatusPath     String?
  serviceLastExitCode   Int?
  serviceLastError      String?
  serviceLastHealthJson String?
  serviceLastCheckedAt  DateTime?
  defaultDevice         String        @default("cuda")
  notes                 String?
  inferHost             InferHost     @relation(fields: [inferHostId], references: [id], onDelete: Cascade)
  evalRuns              EvalRun[]
  liveSessions          LiveSession[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([inferHostId, createdAt])
}

model EvalSuite {
  id             String          @id @default(cuid())
  slug           String          @unique
  title          String
  description    String?
  sourcePath     String
  caseCount      Int             @default(0)
  tagsJson       String?
  status         String          @default("active")
  evalRuns       EvalRun[]
  arenaJudgments ArenaJudgment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model EvalRun {
  id                   String           @id @default(cuid())
  inferHostId          String?
  modelDeploymentId    String?
  evalSuiteId          String?
  title                String
  mode                 String           @default("offline")
  kind                 String           @default("suite_batch")
  status               String           @default("draft")
  outputDir            String?
  logPath              String?
  statusPath           String?
  summaryPath          String?
  tmuxSession          String?
  remoteCommand        String?
  configJson           String?
  resultJson           String?
  error                String?
  startedAt            DateTime?
  finishedAt           DateTime?
  inferHost            InferHost?       @relation(fields: [inferHostId], references: [id], onDelete: SetNull)
  modelDeployment      ModelDeployment? @relation(fields: [modelDeploymentId], references: [id], onDelete: SetNull)
  evalSuite            EvalSuite?       @relation(fields: [evalSuiteId], references: [id], onDelete: SetNull)
  arenaJudgmentsAsLeft ArenaJudgment[]  @relation("ArenaLeftRun")
  arenaJudgmentsAsRight ArenaJudgment[] @relation("ArenaRightRun")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([modelDeploymentId, createdAt])
  @@index([inferHostId, createdAt])
}

model LiveSession {
  id                String           @id @default(cuid())
  inferHostId       String?
  modelDeploymentId String?
  title             String
  status            String           @default("draft")
  scenario          String?
  notes             String?
  transcriptJson    String?
  inferHost         InferHost?       @relation(fields: [inferHostId], references: [id], onDelete: SetNull)
  modelDeployment   ModelDeployment? @relation(fields: [modelDeploymentId], references: [id], onDelete: SetNull)
  turns             LiveTurn[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status, createdAt])
}

model LiveTurn {
  id            String      @id @default(cuid())
  liveSessionId String
  role          String
  content       String
  latencyMs     Int?
  tokenCount    Int?
  rawJson       String?
  liveSession   LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([liveSessionId, createdAt])
}

model ArenaJudgment {
  id                String    @id @default(cuid())
  evalSuiteId       String?
  leftEvalRunId     String
  rightEvalRunId    String
  caseId            String
  caseSlice         String?
  promptPreview     String?
  winner            String    @default("skip")
  winnerEvalRunId   String?
  personaScore      Int?
  judgmentScore     Int?
  premiseScore      Int?
  structureScore    Int?
  actionabilityScore Int?
  naturalnessScore  Int?
  stabilityScore    Int?
  failureTagsJson   String?
  notes             String?
  evalSuite         EvalSuite? @relation(fields: [evalSuiteId], references: [id], onDelete: SetNull)
  leftEvalRun       EvalRun   @relation("ArenaLeftRun", fields: [leftEvalRunId], references: [id], onDelete: Cascade)
  rightEvalRun      EvalRun   @relation("ArenaRightRun", fields: [rightEvalRunId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([leftEvalRunId, rightEvalRunId, caseId])
  @@index([evalSuiteId, createdAt])
  @@index([winnerEvalRunId, createdAt])
}
